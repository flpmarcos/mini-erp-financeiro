@model List<Notificacao>
@{ int naoLidas = ViewBag.NaoLidas; }

<div class="dropdown">
    <button class="btn btn-sm btn-outline-secondary position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notificações">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        @if (naoLidas > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.6rem">@naoLidas</span>
        }
    </button>
    <div class="dropdown-menu dropdown-menu-end shadow" style="width:340px">
        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
            <strong class="small">Notificações</strong>
            <a class="small" asp-controller="Notificacoes" asp-action="Index">ver todas</a>
        </div>
        @if (!Model.Any())
        {
            <div class="px-3 py-3 text-muted small">Sem notificações.</div>
        }
        else
        {
            foreach (var n in Model)
            {
                var dot = n.Severidade == SeveridadeNotificacao.Alerta ? "text-danger"
                        : n.Severidade == SeveridadeNotificacao.Sucesso ? "text-success" : "text-primary";
                <a class="dropdown-item py-2 @(n.Lida ? "" : "fw-semibold")" href="@(n.Link ?? "#")">
                    <div class="d-flex gap-2">
                        <span class="@dot">●</span>
                        <div class="small" style="white-space:normal">
                            <div>@n.Titulo</div>
                            <div class="text-muted">@n.CriadoEm.ToLocalTime().ToString("dd/MM HH:mm")</div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>
