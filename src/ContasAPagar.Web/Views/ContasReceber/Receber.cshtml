@model RecebimentoVM
@{
    ViewData["Title"] = "Receber";
    var conta = (ContaReceber)ViewBag.Conta;
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<h2 class="mb-3">Registrar Recebimento</h2>
<div class="row g-3">
    <div class="col-md-5">
        <div class="card"><div class="card-header">@conta.Descricao</div><div class="card-body">
            <table class="table table-sm mb-0">
                <tr><td>Cliente</td><td>@conta.Cliente?.RazaoSocial</td></tr>
                <tr><td>Valor</td><td>@Moeda(conta.Valor)</td></tr>
                <tr><td>Recebido</td><td>@Moeda(conta.ValorRecebido)</td></tr>
                <tr><td>Saldo</td><td><strong>@Moeda(conta.SaldoAReceber)</strong></td></tr>
            </table>
        </div></div>
    </div>
    <div class="col-md-7">
        <form asp-action="Receber" method="post" class="card card-body">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ContaReceberId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ValorRecebido" class="form-label"></label>
                    <input asp-for="ValorRecebido" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DataRecebimento" class="form-label"></label>
                    <input asp-for="DataRecebimento" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContaBancariaId" class="form-label"></label>
                    <select asp-for="ContaBancariaId" class="form-select" asp-items="ViewBag.ContasBancarias"><option value="">(opcional)</option></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="FormaRecebimento" class="form-label"></label>
                    <select asp-for="FormaRecebimento" class="form-select" asp-items="Html.GetEnumSelectList<FormaPagamento>()"></select>
                </div>
                <div class="col-12">
                    <label asp-for="Observacao" class="form-label"></label>
                    <input asp-for="Observacao" class="form-control" />
                </div>
            </div>
            <div class="mt-3"><button class="btn btn-success">Confirmar Recebimento</button> <a class="btn btn-link" asp-action="Details" asp-route-id="@conta.Id">Cancelar</a></div>
            <p class="text-muted small mt-2 mb-0">Recebimento integral marca como <strong>Recebida</strong>; valor menor marca como <strong>Parcialmente Recebida</strong>.</p>
        </form>
    </div>
</div>
