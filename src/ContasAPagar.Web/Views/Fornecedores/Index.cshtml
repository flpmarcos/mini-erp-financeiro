@model PagedResult<Fornecedor>
@{ ViewData["Title"] = "Fornecedores"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Fornecedores</h2>
    <a class="btn btn-primary" asp-action="Create">+ Novo Fornecedor</a>
</div>

<form method="get" class="mb-3 d-flex gap-2" style="max-width:420px">
    <input name="busca" value="@ViewBag.Busca" class="form-control" placeholder="razão social, fantasia ou documento" />
    <button class="btn btn-dark">Buscar</button>
</form>

<table class="table table-hover bg-white align-middle">
    <thead class="table-light">
        <tr><th>Razão Social</th><th>Fantasia</th><th>Documento</th><th>E-mail</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var f in Model.Itens)
        {
            <tr>
                <td>@f.RazaoSocial</td>
                <td>@f.NomeFantasia</td>
                <td>@f.Documento</td>
                <td>@f.Email</td>
                <td>
                    @{
                        var badge = f.Status == StatusFornecedor.Ativo ? "bg-success"
                                  : f.Status == StatusFornecedor.Bloqueado ? "bg-danger" : "bg-secondary";
                    }
                    <span class="badge @badge">@f.Status</span>
                </td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@f.Id">Editar</a></td>
            </tr>
        }
        @if (!Model.Itens.Any()) { <tr><td colspan="6" class="text-center text-muted py-4">Nenhum fornecedor.</td></tr> }
    </tbody>
</table>

@if (Model.TotalPaginas > 1)
{
    <nav><ul class="pagination">
        @for (int p = 1; p <= Model.TotalPaginas; p++)
        {
            <li class="page-item @(p == Model.Pagina ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-busca="@ViewBag.Busca" asp-route-pagina="@p">@p</a>
            </li>
        }
    </ul></nav>
}
