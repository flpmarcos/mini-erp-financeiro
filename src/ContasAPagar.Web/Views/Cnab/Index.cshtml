@{ ViewData["Title"] = "CNAB"; }

<h2 class="mb-3">CNAB (Remessa & Retorno)</h2>
<p class="text-muted">Módulo didático. Formato simplificado (não é CNAB 240/400 real).</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100"><div class="card-header">1 · Gerar Remessa</div><div class="card-body">
            <p class="small text-muted">Gera um arquivo <code>.rem</code> com as contas liberadas/pendentes a pagar.</p>
            <a class="btn btn-primary" asp-action="GerarRemessa">Baixar Remessa</a>
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="card h-100"><div class="card-header">2 · Processar Retorno</div><div class="card-body">
            <p class="small text-muted">Envie o arquivo de retorno do banco. Linhas com código <code>00</code> confirmam o pagamento; <code>09</code> rejeitam; demais são ignoradas.</p>
            <form asp-action="ProcessarRetorno" method="post" enctype="multipart/form-data" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input type="file" name="arquivo" class="form-control" accept=".ret,.txt,.rem" />
                <button class="btn btn-success">Processar</button>
            </form>
        </div></div>
    </div>
</div>

<div class="card mt-4"><div class="card-header">Layout (didático)</div><div class="card-body">
<pre class="mb-0"><code>Remessa: R{contaId:8}{valorCentavos:13}
Retorno: T{contaId:8}{valorCentavos:13}{codigo:2}   (00=pago, 09=rejeitado)</code></pre>
</div></div>
