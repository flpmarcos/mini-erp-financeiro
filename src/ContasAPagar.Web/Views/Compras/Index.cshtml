@model List<SolicitacaoCompra>
@{
    ViewData["Title"] = "Compras";
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Solicitações de Compra</h2>
    <a class="btn btn-primary" asp-action="Create">+ Nova Solicitação</a>
</div>
<p class="text-muted">Fluxo: Solicitada → Aprovada → Pedido Emitido → Recebida (gera Conta a Pagar).</p>

<table class="table table-hover table-sm bg-white align-middle">
    <thead class="table-light">
        <tr><th>Descrição</th><th>Fornecedor</th><th>Categoria</th><th class="text-end">Estimado</th><th>Status</th><th>AP</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Descricao</td>
                <td>@s.Fornecedor?.NomeFantasia</td>
                <td>@s.Categoria?.Nome</td>
                <td class="text-end">@Moeda(s.ValorEstimado)</td>
                <td><span class="badge @UiHelpers.BadgeCompra(s.Status)">@s.Status</span></td>
                <td>@(s.ContaPagarGeradaId.HasValue ? $"#{s.ContaPagarGeradaId}" : "—")</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@s.Id">Abrir</a></td>
            </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">Nenhuma solicitação.</td></tr> }
    </tbody>
</table>
