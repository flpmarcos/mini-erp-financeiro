@model CompraFormVM
@{ ViewData["Title"] = "Nova Solicitação de Compra"; }

<h2 class="mb-3">Nova Solicitação de Compra</h2>
<form asp-action="Create" method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Descricao" class="form-label"></label>
            <input asp-for="Descricao" class="form-control" />
            <span asp-validation-for="Descricao" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="ValorEstimado" class="form-label"></label>
            <input asp-for="ValorEstimado" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="ValorEstimado" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="FornecedorId" class="form-label"></label>
            <select asp-for="FornecedorId" class="form-select" asp-items="ViewBag.Fornecedores"><option value="">selecione...</option></select>
        </div>
        <div class="col-md-4">
            <label asp-for="CategoriaId" class="form-label"></label>
            <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias"><option value="">selecione...</option></select>
        </div>
        <div class="col-md-4">
            <label asp-for="CentroCustoId" class="form-label"></label>
            <select asp-for="CentroCustoId" class="form-select" asp-items="ViewBag.Centros"><option value="">selecione...</option></select>
        </div>
        <div class="col-12">
            <label asp-for="Justificativa" class="form-label"></label>
            <textarea asp-for="Justificativa" class="form-control" rows="2"></textarea>
        </div>
    </div>
    <div class="mt-3"><button class="btn btn-primary">Solicitar</button> <a class="btn btn-link" asp-action="Index">Cancelar</a></div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
