@{
    ViewData["Title"] = "Cadastros";
    var categorias = (List<Categoria>)ViewBag.Categorias;
    var centros = (List<CentroCusto>)ViewBag.Centros;
    var contas = (List<ContaBancaria>)ViewBag.ContasBancarias;
}

<h2 class="mb-3">Cadastros Auxiliares</h2>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card"><div class="card-header">Categorias</div>
            <ul class="list-group list-group-flush">
                @foreach (var c in categorias) { <li class="list-group-item">@c.Nome</li> }
            </ul>
            <div class="card-body">
                <form asp-action="CriarCategoria" method="post" class="d-flex gap-1">
                    @Html.AntiForgeryToken()
                    <input name="Nome" class="form-control form-control-sm" placeholder="nova categoria" />
                    <button class="btn btn-sm btn-primary">+</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card"><div class="card-header">Centros de Custo</div>
            <ul class="list-group list-group-flush">
                @foreach (var c in centros) { <li class="list-group-item"><strong>@c.Codigo</strong> · @c.Nome</li> }
            </ul>
            <div class="card-body">
                <form asp-action="CriarCentro" method="post" class="row g-1">
                    @Html.AntiForgeryToken()
                    <div class="col-4"><input name="Codigo" class="form-control form-control-sm" placeholder="cód" /></div>
                    <div class="col-6"><input name="Nome" class="form-control form-control-sm" placeholder="nome" /></div>
                    <div class="col-2"><button class="btn btn-sm btn-primary w-100">+</button></div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card"><div class="card-header">Contas Bancárias (empresa)</div>
            <ul class="list-group list-group-flush">
                @foreach (var c in contas) { <li class="list-group-item">@c.Nome <span class="text-muted small">(@c.Banco)</span></li> }
            </ul>
            <div class="card-body">
                <form asp-action="CriarContaBancaria" method="post" class="row g-1">
                    @Html.AntiForgeryToken()
                    <div class="col-6"><input name="Nome" class="form-control form-control-sm" placeholder="nome" /></div>
                    <div class="col-4"><input name="Banco" class="form-control form-control-sm" placeholder="banco" /></div>
                    <div class="col-2"><button class="btn btn-sm btn-primary w-100">+</button></div>
                </form>
            </div>
        </div>
    </div>
</div>
