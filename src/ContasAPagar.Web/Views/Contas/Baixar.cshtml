@model BaixaVM
@{
    ViewData["Title"] = "Baixar Conta";
    var conta = (ContaPagar)ViewBag.Conta;
    var enc = (CalculoEncargos)ViewBag.Encargos;
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<h2 class="mb-3">Pagar / Baixar Conta</h2>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card"><div class="card-header">@conta.Descricao</div><div class="card-body">
            <table class="table table-sm mb-0">
                <tr><td>Fornecedor</td><td>@conta.Fornecedor?.RazaoSocial</td></tr>
                <tr><td>Valor Líquido</td><td>@Moeda(conta.ValorLiquido)</td></tr>
                <tr><td>Já pago</td><td>@Moeda(conta.ValorPago)</td></tr>
                <tr><td>Saldo Devedor</td><td>@Moeda(conta.SaldoDevedor)</td></tr>
                @if (enc.DiasAtraso > 0)
                {
                    <tr class="table-danger"><td>Atraso</td><td>@enc.DiasAtraso dia(s)</td></tr>
                    <tr class="table-danger"><td>Multa + Juros</td><td>@Moeda(enc.Multa + enc.Juros)</td></tr>
                    <tr class="table-danger"><td><strong>Valor Atualizado</strong></td><td><strong>@Moeda(enc.ValorAtualizado)</strong></td></tr>
                }
            </table>
        </div></div>
    </div>

    <div class="col-md-7">
        <form asp-action="Baixar" method="post" class="card card-body">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ContaPagarId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ValorPago" class="form-label"></label>
                    <input asp-for="ValorPago" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DataPagamento" class="form-label"></label>
                    <input asp-for="DataPagamento" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContaBancariaId" class="form-label"></label>
                    <select asp-for="ContaBancariaId" class="form-select" asp-items="ViewBag.ContasBancarias"><option value="">selecione...</option></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="FormaPagamento" class="form-label"></label>
                    <select asp-for="FormaPagamento" class="form-select" asp-items="Html.GetEnumSelectList<FormaPagamento>()"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Comprovante" class="form-label"></label>
                    <input asp-for="Comprovante" class="form-control" placeholder="nº comprovante (opcional)" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Observacao" class="form-label"></label>
                    <input asp-for="Observacao" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Justificativa" class="form-label"></label>
                    <input asp-for="Justificativa" class="form-control" placeholder="obrigatória se valor pago > saldo devedor" />
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-success">Confirmar Pagamento</button>
                <a class="btn btn-link" asp-action="Details" asp-route-id="@conta.Id">Cancelar</a>
            </div>
            <p class="text-muted small mt-2 mb-0">
                Pagamento integral marca como <strong>Paga</strong>; valor menor marca como <strong>Parcialmente Paga</strong>.
                A integração bancária é simulada e pode retornar sucesso, pendente ou erro.
            </p>
        </form>
    </div>
</div>
