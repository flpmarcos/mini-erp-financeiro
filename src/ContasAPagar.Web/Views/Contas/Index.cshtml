@model PagedResult<ContaPagar>
@{
    ViewData["Title"] = "Contas a Pagar";
    var f = (ContaPagarFiltroVM)ViewBag.Filtro;
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Contas a Pagar</h2>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Parcelar">+ Parcelamento</a>
        <a class="btn btn-primary" asp-action="Create">+ Nova Conta</a>
    </div>
</div>

<form method="get" class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label small">Status</label>
            <select name="Status" class="form-select" asp-items="ViewBag.Status">
                <option value="">(todos)</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small">Fornecedor</label>
            <select name="FornecedorId" class="form-select" asp-items="ViewBag.Fornecedores">
                <option value="">(todos)</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Centro de Custo</label>
            <select name="CentroCustoId" class="form-select" asp-items="ViewBag.Centros">
                <option value="">(todos)</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Venc. de</label>
            <input type="date" name="VencimentoDe" class="form-control" value="@f.VencimentoDe?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Venc. até</label>
            <input type="date" name="VencimentoAte" class="form-control" value="@f.VencimentoAte?.ToString("yyyy-MM-dd")" />
        </div>
    </div>
    <div class="mt-2">
        <button class="btn btn-sm btn-dark" type="submit">Filtrar</button>
        <a class="btn btn-sm btn-link" asp-action="Index">Limpar</a>
    </div>
</form>

<table class="table table-hover table-sm align-middle bg-white">
    <thead class="table-light">
        <tr>
            <th>Descrição</th><th>Fornecedor</th><th>Categoria</th><th>Vencimento</th>
            <th class="text-end">Valor Líq.</th><th class="text-end">Saldo</th><th>Status</th><th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Itens)
        {
            <tr>
                <td>@c.Descricao</td>
                <td>@c.Fornecedor?.NomeFantasia</td>
                <td>@c.Categoria?.Nome</td>
                <td>@c.DataVencimento.ToShortDateString()</td>
                <td class="text-end">@Moeda(c.ValorLiquido)</td>
                <td class="text-end">@Moeda(c.SaldoDevedor)</td>
                <td><span class="badge @UiHelpers.BadgeConta(c.Status)">@c.Status</span></td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id">Abrir</a></td>
            </tr>
        }
        @if (!Model.Itens.Any()) { <tr><td colspan="8" class="text-center text-muted py-4">Nenhuma conta encontrada.</td></tr> }
    </tbody>
</table>

@if (Model.TotalPaginas > 1)
{
    <nav>
        <ul class="pagination">
            @for (int p = 1; p <= Model.TotalPaginas; p++)
            {
                <li class="page-item @(p == Model.Pagina ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-Status="@f.Status"
                       asp-route-FornecedorId="@f.FornecedorId"
                       asp-route-CentroCustoId="@f.CentroCustoId"
                       asp-route-VencimentoDe="@f.VencimentoDe?.ToString("yyyy-MM-dd")"
                       asp-route-VencimentoAte="@f.VencimentoAte?.ToString("yyyy-MM-dd")"
                       asp-route-Pagina="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
<p class="text-muted small">@Model.TotalItens conta(s) · página @Model.Pagina de @Model.TotalPaginas</p>
