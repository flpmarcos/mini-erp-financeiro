@model ContaPagarFormVM

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Descricao" class="form-label"></label>
        <input asp-for="Descricao" class="form-control" />
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ValorOriginal" class="form-label"></label>
        <input asp-for="ValorOriginal" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="ValorOriginal" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="FornecedorId" class="form-label"></label>
        <select asp-for="FornecedorId" class="form-select" asp-items="ViewBag.Fornecedores">
            <option value="">selecione...</option>
        </select>
        <span asp-validation-for="FornecedorId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CategoriaId" class="form-label"></label>
        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias">
            <option value="">selecione...</option>
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="CentroCustoId" class="form-label"></label>
        <select asp-for="CentroCustoId" class="form-select" asp-items="ViewBag.Centros">
            <option value="">selecione...</option>
        </select>
        <span asp-validation-for="CentroCustoId" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="DataEmissao" class="form-label"></label>
        <input asp-for="DataEmissao" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="DataCompetencia" class="form-label"></label>
        <input asp-for="DataCompetencia" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="DataVencimento" class="form-label"></label>
        <input asp-for="DataVencimento" class="form-control" type="date" />
        <span asp-validation-for="DataVencimento" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="FormaPagamento" class="form-label"></label>
        <select asp-for="FormaPagamento" class="form-select" asp-items="Html.GetEnumSelectList<FormaPagamento>()"></select>
    </div>

    <div class="col-md-6">
        <label asp-for="CodigoBarras" class="form-label"></label>
        <input asp-for="CodigoBarras" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ChavePix" class="form-label"></label>
        <input asp-for="ChavePix" class="form-control" />
    </div>

    <div class="col-12">
        <label asp-for="Observacao" class="form-label"></label>
        <textarea asp-for="Observacao" class="form-control" rows="2"></textarea>
    </div>
</div>

<div class="card mt-3"><div class="card-header">Retenção de Impostos (informe a alíquota %, deixe 0 para não reter)</div>
    <div class="card-body"><div class="row g-2">
        @for (int i = 0; i < Model.Retencoes.Count; i++)
        {
            <div class="col-md-2 col-4">
                <label class="form-label small">@Model.Retencoes[i].Tipo</label>
                <input type="hidden" asp-for="Retencoes[i].Tipo" />
                <input asp-for="Retencoes[i].Aliquota" class="form-control form-control-sm" type="number" step="0.01" min="0" max="100" />
            </div>
        }
    </div></div>
</div>

<div class="mt-3">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a class="btn btn-link" asp-action="Index">Cancelar</a>
</div>
