@model List<RegraAprovacao>
@{
    ViewData["Title"] = "Regras de Aprovação";
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Workflow de Aprovação</h2>
    <a class="btn btn-primary" asp-action="Create">+ Nova Regra</a>
</div>
<p class="text-muted">A regra <strong>ativa mais específica</strong> que cobre o valor da conta define a alçada. Sem regra, usa a alçada por valor padrão.</p>

<table class="table bg-white align-middle">
    <thead class="table-light">
        <tr><th>Nome</th><th class="text-end">Faixa</th><th>Categoria</th><th>Centro</th><th>Fornecedor</th><th>Nível</th><th>Ativa</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Nome</td>
                <td class="text-end">@Moeda(r.ValorMinimo) – @(r.ValorMaximo.HasValue ? Moeda(r.ValorMaximo.Value) : "∞")</td>
                <td>@(r.Categoria?.Nome ?? "—")</td>
                <td>@(r.CentroCusto?.Nome ?? "—")</td>
                <td>@(r.Fornecedor?.NomeFantasia ?? "—")</td>
                <td><span class="badge bg-primary">@r.NivelExigido</span></td>
                <td>@(r.Ativa ? "Sim" : "Não")</td>
                <td class="d-flex gap-1">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.Id">Editar</a>
                    <form asp-action="Delete" asp-route-id="@r.Id" method="post" onsubmit="return confirm('Remover regra?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">×</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="8" class="text-center text-muted py-4">Nenhuma regra. Usando alçada por valor padrão.</td></tr> }
    </tbody>
</table>
