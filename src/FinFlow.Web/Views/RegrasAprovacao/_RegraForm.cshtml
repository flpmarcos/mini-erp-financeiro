@model RegraAprovacao

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" asp-for="Id" />
<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Nome" class="form-label">Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="Ativa" class="form-check-input" />
            <label asp-for="Ativa" class="form-check-label">Ativa</label>
        </div>
    </div>
    <div class="col-md-3">
        <label asp-for="ValorMinimo" class="form-label">Valor mínimo</label>
        <input asp-for="ValorMinimo" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-3">
        <label asp-for="ValorMaximo" class="form-label">Valor máximo (vazio = ∞)</label>
        <input asp-for="ValorMaximo" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-3">
        <label asp-for="NivelExigido" class="form-label">Nível exigido</label>
        <select asp-for="NivelExigido" class="form-select" asp-items="Html.GetEnumSelectList<FinFlow.Domain.Enums.NivelAprovacao>()"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="CategoriaId" class="form-label">Categoria (opcional)</label>
        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias"><option value="">(qualquer)</option></select>
    </div>
    <div class="col-md-4">
        <label asp-for="CentroCustoId" class="form-label">Centro de custo (opcional)</label>
        <select asp-for="CentroCustoId" class="form-select" asp-items="ViewBag.Centros"><option value="">(qualquer)</option></select>
    </div>
    <div class="col-md-4">
        <label asp-for="FornecedorId" class="form-label">Fornecedor (opcional)</label>
        <select asp-for="FornecedorId" class="form-select" asp-items="ViewBag.Fornecedores"><option value="">(qualquer)</option></select>
    </div>
</div>
<div class="mt-3"><button class="btn btn-primary">Salvar</button> <a class="btn btn-link" asp-action="Index">Cancelar</a></div>
