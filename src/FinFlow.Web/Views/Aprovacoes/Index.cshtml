@model List<ContaPagar>
@{
    ViewData["Title"] = "Aprovações";
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<h2 class="mb-3">Contas Aguardando Aprovação</h2>
<p class="text-muted">
    Alçada: &lt; R$ 1.000 auto · R$ 1.000–10.000 gerente · &gt; R$ 10.000 diretor.
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhuma conta aguardando aprovação.</div>
}
else
{
    <table class="table bg-white align-middle">
        <thead class="table-light">
            <tr><th>Conta</th><th>Fornecedor</th><th class="text-end">Valor</th><th>Nível</th><th style="width:340px">Decisão</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                var nivel = c.Aprovacoes.FirstOrDefault(a => a.Resultado == ResultadoAprovacao.Pendente)?.NivelExigido;
                <tr>
                    <td><a asp-controller="Contas" asp-action="Details" asp-route-id="@c.Id">@c.Descricao</a></td>
                    <td>@c.Fornecedor?.NomeFantasia</td>
                    <td class="text-end">@Moeda(c.ValorLiquido)</td>
                    <td><span class="badge bg-warning text-dark">@nivel</span></td>
                    <td>
                        <div class="d-flex gap-2">
                            <form asp-action="Aprovar" method="post" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ContaPagarId" value="@c.Id" />
                                <input name="Aprovador" class="form-control form-control-sm" placeholder="aprovador" style="width:120px" />
                                <button class="btn btn-sm btn-success">Aprovar</button>
                            </form>
                            <form asp-action="Reprovar" method="post" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ContaPagarId" value="@c.Id" />
                                <button class="btn btn-sm btn-outline-danger">Reprovar</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
