@model List<ContaPagar>
@{
    ViewData["Title"] = (string)ViewBag.Titulo;
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<div class="d-flex justify-content-between mb-3">
    <h2>@ViewBag.Titulo</h2>
    <a class="btn btn-outline-secondary" asp-action="Index">← Relatórios</a>
</div>

<table class="table table-sm bg-white align-middle">
    <thead class="table-light">
        <tr><th>Descrição</th><th>Fornecedor</th><th>Vencimento</th><th>Pagamento</th><th class="text-end">Líquido</th><th class="text-end">Saldo</th><th>Status</th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td><a asp-controller="Contas" asp-action="Details" asp-route-id="@c.Id">@c.Descricao</a></td>
                <td>@c.Fornecedor?.NomeFantasia</td>
                <td>@c.DataVencimento.ToShortDateString()</td>
                <td>@(c.DataPagamento?.ToShortDateString() ?? "-")</td>
                <td class="text-end">@Moeda(c.ValorLiquido)</td>
                <td class="text-end">@Moeda(c.SaldoDevedor)</td>
                <td><span class="badge @UiHelpers.BadgeConta(c.Status)">@c.Status</span></td>
            </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">Sem dados.</td></tr> }
    </tbody>
    @if (Model.Any())
    {
        <tfoot><tr class="table-light fw-bold">
            <td colspan="4">Total (@Model.Count)</td>
            <td class="text-end">@Moeda(Model.Sum(c => c.ValorLiquido))</td>
            <td class="text-end">@Moeda(Model.Sum(c => c.SaldoDevedor))</td>
            <td></td>
        </tr></tfoot>
    }
</table>
