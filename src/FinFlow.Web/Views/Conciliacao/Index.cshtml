@model List<ExtratoBancarioItem>
@{
    ViewData["Title"] = "Conciliação Bancária";
    string Moeda(decimal v) => v.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
}

<h2 class="mb-3">Conciliação Bancária</h2>

<div class="card card-body mb-4">
    <form asp-action="Importar" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
        @Html.AntiForgeryToken()
        <input type="file" name="arquivo" accept=".csv" class="form-control" style="max-width:380px" />
        <button class="btn btn-primary">Importar Extrato CSV</button>
        <span class="text-muted small">Formato: <code>Data;Descricao;Valor;Documento;Banco;Tipo</code> (delimitador ;)</span>
    </form>
</div>

<table class="table table-sm bg-white align-middle">
    <thead class="table-light">
        <tr><th>Data</th><th>Descrição</th><th class="text-end">Valor</th><th>Documento</th><th>Banco</th><th>Status</th><th>Conta</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Data.ToShortDateString()</td>
                <td>@e.Descricao</td>
                <td class="text-end">@Moeda(e.Valor)</td>
                <td>@e.Documento</td>
                <td>@e.Banco</td>
                <td><span class="badge @UiHelpers.BadgeConciliacao(e.Status)">@e.Status</span></td>
                <td>
                    @if (e.ContaPagarId.HasValue)
                    { <a asp-controller="Contas" asp-action="Details" asp-route-id="@e.ContaPagarId">Pagar #@e.ContaPagarId</a> }
                    else if (e.ContaReceberId.HasValue)
                    { <a asp-controller="ContasReceber" asp-action="Details" asp-route-id="@e.ContaReceberId">Receber #@e.ContaReceberId</a> }
                </td>
                <td>
                    @if (e.Status != StatusConciliacao.Conciliado)
                    {
                        <div class="d-flex gap-1">
                            <form asp-action="ConciliarManual" method="post" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="extratoItemId" value="@e.Id" />
                                <input type="number" name="contaPagarId" class="form-control form-control-sm" placeholder="AP id" style="width:80px" />
                                <button class="btn btn-sm btn-outline-success" title="Conciliar com Conta a Pagar">AP</button>
                            </form>
                            <form asp-action="ConciliarReceber" method="post" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="extratoItemId" value="@e.Id" />
                                <input type="number" name="contaReceberId" class="form-control form-control-sm" placeholder="AR id" style="width:80px" />
                                <button class="btn btn-sm btn-outline-primary" title="Conciliar com Conta a Receber">AR</button>
                            </form>
                        </div>
                    }
                </td>
            </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="8" class="text-center text-muted py-4">Nenhum lançamento importado. Use o arquivo <code>extrato-exemplo.csv</code>.</td></tr> }
    </tbody>
</table>
