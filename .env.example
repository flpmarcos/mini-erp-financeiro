# ============================================================================
# FinFlow — variáveis de ambiente para o docker-compose / Coolify.
# Copie para .env (local) ou defina nas Settings do app no Coolify.
# ============================================================================

# Provider do banco: InMemory (default, dados voláteis) | SqlServer | Oracle
DATABASE_PROVIDER=InMemory

# Connection string do banco (deixe VAZIA para InMemory). Exemplos:
#   SqlServer: Server=sqlserver,1433;Database=FinFlow;User Id=sa;Password=SUA_SENHA_FORTE;TrustServerCertificate=True;
#   Oracle:    User Id=appuser;Password=SUA_SENHA;Data Source=oracle:1521/FREEPDB1;
CONNECTION_STRING=

# Token exigido no header X-Webhook-Token do webhook bancário. TROQUE!
BANK_WEBHOOK_TOKEN=troque-este-token

# Senha do SQL Server (apenas se habilitar o serviço sqlserver no compose).
MSSQL_SA_PASSWORD=
